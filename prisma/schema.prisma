// Cucerdos Mundial - Schema
// PostgreSQL + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ TORNEO ============
model Torneo {
  id          String   @id @default(cuid())
  nombre      String
  slug        String   @unique
  ano         Int      // 2026
  activo      Boolean  @default(true)
  precioPaisBase Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participantes Participante[]
  paises        Pais[]
  partidos      Partido[]
  duelos        Duelo[]
  deudas        Deuda[]
  jornadas      Jornada[]
}

// ============ JORNADA (para agrupar partidos) ============
model Jornada {
  id        String   @id @default(cuid())
  torneoId  String
  torneo    Torneo   @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  nombre    String   // "Fase de grupos", "Octavos", etc.
  numero    Int
  cerrada   Boolean  @default(false)
  partidos  Partido[]
}

// ============ PARTICIPANTE (amigo en la quiniela) ============
model Participante {
  id          String   @id @default(cuid())
  torneoId    String
  torneo      Torneo   @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  nombre      String
  apodo       String?
  email       String?
  avatarUrl   String?
  colorHex    String?  @default("#6366f1") // color de perfil
  saldo       Decimal  @default(0) @db.Decimal(10, 2) // puede ser negativo = debe
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paisesAsignados PaisAsignacion[]
  duelosComoA     Duelo[]         @relation("ParticipanteA")
  duelosComoB     Duelo[]         @relation("ParticipanteB")
  deudasComoDeudor   Deuda[]      @relation("Deudor")
  deudasComoAcreedor  Deuda[]     @relation("Acreedor")
  duelosGanados      Duelo[]     @relation("GanadorDuelos")
  picks             Pick[]       // apuestas / predicciones por partido
}

// ============ PAÍS / SELECCIÓN ============
model Pais {
  id            String   @id @default(cuid())
  torneoId      String
  torneo        Torneo   @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  nombre        String
  codigoFifa    String   // ARG, BRA, FRA...
  banderaUrl    String?
  grupo         String?  // A, B, C...
  puntos        Int      @default(0)
  golesFavor    Int      @default(0)
  golesContra   Int      @default(0)
  estado        String   @default("vivo") // vivo | eliminado | campeon
  valorSimbolico Decimal? @db.Decimal(10, 2)

  @@unique([torneoId, codigoFifa])
  asignaciones PaisAsignacion[]
  partidosLocal   Partido[] @relation("Local")
  partidosVisitante Partido[] @relation("Visitante")
  partidosGanados  Partido[] @relation("GanadorPartido")
}

// Relación N:N Participante - País (cada amigo tiene N países)
model PaisAsignacion {
  id             String   @id @default(cuid())
  participanteId String
  paisId         String
  participante   Participante @relation(fields: [participanteId], references: [id], onDelete: Cascade)
  pais           Pais     @relation(fields: [paisId], references: [id], onDelete: Cascade)
  asignadoEn     DateTime @default(now())

  @@unique([participanteId, paisId])
  @@index([participanteId])
  @@index([paisId])
}

// ============ PARTIDO ============
model Partido {
  id            String   @id @default(cuid())
  torneoId      String
  torneo        Torneo   @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  jornadaId     String?
  jornada       Jornada? @relation(fields: [jornadaId], references: [id], onDelete: SetNull)
  localId       String
  visitanteId   String
  local         Pais     @relation("Local", fields: [localId], references: [id], onDelete: Cascade)
  visitante     Pais     @relation("Visitante", fields: [visitanteId], references: [id], onDelete: Cascade)
  // Para armar UI (tabs + llave) sin depender de nombres libres en Jornada
  fase          String   @default("grupos") // grupos | octavos | cuartos | semis | final | tercero | etc.
  grupo         String?  // opcional: A, B, C... (solo fase de grupos)
  orden         Int?     // slot/orden dentro de la fase (útil para dibujar la llave)
  ganadorId     String?
  ganador       Pais?    @relation("GanadorPartido", fields: [ganadorId], references: [id], onDelete: SetNull)
  fecha         DateTime
  estadio       String?
  golesLocal    Int?
  golesVisitante Int?
  estado        String   @default("pendiente") // pendiente | jugado | cancelado

  duelos  Duelo[]
  picks   Pick[]

  @@index([torneoId, fase])
  @@index([torneoId, fase, orden])
}

// ============ DUELO (cruce entre amigos cuando juegan sus países) ============
model Duelo {
  id              String   @id @default(cuid())
  torneoId        String
  torneo          Torneo   @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  partidoId       String
  partido         Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  participanteAId String
  participanteBId String
  participanteA   Participante @relation("ParticipanteA", fields: [participanteAId], references: [id], onDelete: Cascade)
  participanteB   Participante @relation("ParticipanteB", fields: [participanteBId], references: [id], onDelete: Cascade)
  paisAId         String?  // país del participante A en este partido
  paisBId         String?  // país del participante B
  montoApostado   Decimal  @db.Decimal(10, 2) @default(0)
  ganadorId       String?  // quien ganó el duelo (participante o null si empate)
  ganador         Participante? @relation("GanadorDuelos", fields: [ganadorId], references: [id], onDelete: SetNull)
  estado          String   @default("pendiente") // pendiente | resuelto | empate

  @@index([partidoId])
  @@index([participanteAId, participanteBId])
}

// ============ PICK (apuesta/predicción de un participante en un partido) ============
model Pick {
  id              String   @id @default(cuid())
  participanteId  String
  partidoId       String
  participante    Participante @relation(fields: [participanteId], references: [id], onDelete: Cascade)
  partido         Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  resultado       String   // "local" | "visitante" | "empate"
  montoApostado   Decimal? @db.Decimal(10, 2)
  acerto          Boolean?
  createdAt       DateTime @default(now())

  @@unique([participanteId, partidoId])
  @@index([partidoId])
}

// ============ DEUDA / PAGO ============
model Deuda {
  id              String   @id @default(cuid())
  torneoId        String
  torneo          Torneo   @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  deudorId        String
  acreedorId      String
  deudor          Participante @relation("Deudor", fields: [deudorId], references: [id], onDelete: Cascade)
  acreedor        Participante @relation("Acreedor", fields: [acreedorId], references: [id], onDelete: Cascade)
  monto           Decimal  @db.Decimal(10, 2)
  razon           String?  // "victoria Brasil", "apuesta partido X", etc.
  referenciaId    String?  // id del duelo o pick que originó la deuda
  tipoReferencia  String?  // "duelo" | "pick" | "manual"
  estado          String   @default("pendiente") // pendiente | pagado | perdonado
  pagadoEn        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([deudorId])
  @@index([acreedorId])
  @@index([torneoId])
}
